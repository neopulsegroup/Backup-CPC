rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAccountEnabled() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active != false
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blocked != true;
    }
    
    function userRoleRaw() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function userRole() {
      return userRoleRaw() in ['Admin', 'ADMIN'] ? 'admin'
        : userRoleRaw() in ['Manager', 'MANAGER'] ? 'manager'
        : userRoleRaw() in ['Coordinator', 'COORDINATOR'] ? 'coordinator'
        : userRoleRaw() in ['Mediator', 'MEDIATOR'] ? 'mediator'
        : userRoleRaw() in ['Lawyer', 'LAWYER'] ? 'lawyer'
        : userRoleRaw() in ['Psychologist', 'PSYCHOLOGIST'] ? 'psychologist'
        : userRoleRaw() in ['Trainer', 'TRAINER'] ? 'trainer'
        : userRoleRaw();
    }

    // Helper function to check if user has a specific role
    function hasRole(role) {
      return userRole() == role;
    }

    function isCpcStaff() {
      return isAccountEnabled() && userRole() in ['admin', 'mediator', 'lawyer', 'psychologist', 'manager', 'coordinator', 'trainer'];
    }

    function canManageCpcTeam() {
      return isAccountEnabled() && userRole() in ['admin', 'manager', 'coordinator'];
    }

    function isCompany() {
      return isAccountEnabled() && userRole() == 'company';
    }

    function isMigrant() {
      return isAccountEnabled() && userRole() == 'migrant';
    }

    function jobOffer(jobId) {
      return get(/databases/$(database)/documents/job_offers/$(jobId));
    }

    // Users collection
    match /users/{userId} {
      allow read: if (isAuthenticated() && isOwner(userId)) || isCpcStaff();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if (isAccountEnabled() && hasRole('admin')) || (
        isAccountEnabled() && isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.active == resource.data.active &&
        request.resource.data.blocked == resource.data.blocked &&
        request.resource.data.blockedAt == resource.data.blockedAt &&
        request.resource.data.blockedBy == resource.data.blockedBy &&
        request.resource.data.disabledAt == resource.data.disabledAt
      );
      allow delete: if isAccountEnabled() && hasRole('admin') && resource.data.role == 'migrant';
    }
    
    // Profiles collection
    match /profiles/{userId} {
      allow read: if isAccountEnabled() && (isOwner(userId) || isCpcStaff());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAccountEnabled() && (isOwner(userId) || hasRole('admin'));
      allow delete: if isAccountEnabled() && hasRole('admin');
    }
    
    // Triage collection
    match /triage/{userId} {
      allow read: if isAccountEnabled() && (isOwner(userId) || isCpcStaff());
      allow write: if isAccountEnabled() && isOwner(userId);
      allow delete: if isAccountEnabled() && hasRole('admin');
    }

    match /i18n/{docId} {
      allow read: if true;
      allow write: if canManageCpcTeam();
    }

    match /i18n_overrides/{docId} {
      allow read: if true;
      allow write: if canManageCpcTeam();
    }
    
    // Companies collection
    match /companies/{companyId} {
      allow read: if true; // Public read for job listings
      allow write: if isAccountEnabled(); // Refine this later
    }

    // Job offers
    match /job_offers/{jobId} {
      allow read: if isAccountEnabled() &&
        (
          resource.data.status == 'active' ||
          isCpcStaff() ||
          (isCompany() && resource.data.company_id == request.auth.uid)
        );
      allow create: if isCompany() &&
        request.resource.data.company_id == request.auth.uid;
      allow update: if isCpcStaff() ||
        (isCompany() && resource.data.company_id == request.auth.uid);
      allow delete: if isCpcStaff();
    }

    // Job applications
    match /job_applications/{applicationId} {
      allow read: if isCpcStaff() ||
        (isAccountEnabled() && resource.data.applicant_id == request.auth.uid) ||
        (
          isCompany() &&
          jobOffer(resource.data.job_id).exists() &&
          jobOffer(resource.data.job_id).data.company_id == request.auth.uid
        );
      allow create: if isAccountEnabled() &&
        request.resource.data.applicant_id == request.auth.uid &&
        jobOffer(request.resource.data.job_id).exists();
      allow update: if isCpcStaff() ||
        (
          isCompany() &&
          jobOffer(resource.data.job_id).exists() &&
          jobOffer(resource.data.job_id).data.company_id == request.auth.uid
        );
      allow delete: if isCpcStaff();
    }

    // Trails and modules (content)
    match /trails/{trailId} {
      allow read: if isAccountEnabled();
      allow write: if isCpcStaff();
    }

    match /trail_modules/{moduleId} {
      allow read: if isAccountEnabled();
      allow write: if isCpcStaff();
    }

    // Trail progress
    match /user_trail_progress/{progressId} {
      allow read: if isCpcStaff() || (isAccountEnabled() && resource.data.user_id == request.auth.uid);
      allow create: if isCpcStaff() || (isAccountEnabled() && request.resource.data.user_id == request.auth.uid);
      allow update: if isCpcStaff() || (isAccountEnabled() && resource.data.user_id == request.auth.uid);
      allow delete: if isCpcStaff();
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if isCpcStaff() ||
        (
          isAccountEnabled() &&
          (
            resource.data.migrant_id == request.auth.uid ||
            resource.data.professional_id == request.auth.uid
          )
        );
      allow create: if isCpcStaff() ||
        (isAccountEnabled() && request.resource.data.migrant_id == request.auth.uid);
      allow update: if isCpcStaff() ||
        (isAccountEnabled() && resource.data.migrant_id == request.auth.uid);
      allow delete: if isCpcStaff();
    }

    match /audit_logs/{logId} {
      allow read: if isAccountEnabled() && hasRole('admin');
      allow create: if isAccountEnabled() && hasRole('admin') && request.resource.data.actor_id == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
